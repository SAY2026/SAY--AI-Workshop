<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAY CLASS | 两滴油的故事 - 李丫丫</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&family=Poppins:wght@400;600&display=swap');
        
        body { font-family: 'Poppins', 'Noto Sans SC', sans-serif; background-color: #f8fafc; }
        .ai-avatar { border: 4px solid #3b82f6; box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.5); }
        .speech-bubble { position: relative; background: #ffffff; border-radius: 1.5rem; border: 1px solid #e2e8f0; }
        .speech-bubble::after {
            content: ''; position: absolute; left: -10px; top: 20px;
            border-style: solid; border-width: 10px 10px 10px 0; border-color: transparent #ffffff transparent transparent;
        }
        .step-active { background-color: #3b82f6 !important; color: white !important; }
    </style>
</head>
<body class="text-slate-800">

    <nav class="bg-white border-b sticky top-0 z-50 px-4 py-3 flex justify-between items-center shadow-sm">
        <div class="flex items-center gap-2">
            <div class="bg-blue-600 text-white p-2 rounded-lg font-bold text-xl">SAY</div>
            <span class="font-semibold text-slate-600 hidden md:block">Hub 中控系统</span>
        </div>
        
        <div class="flex-1 mx-8 hidden lg:block">
            <div class="w-full bg-slate-200 h-2 rounded-full overflow-hidden">
                <div id="progressBar" class="bg-blue-600 h-full transition-all duration-500" style="width: 20%"></div>
            </div>
        </div>

        <div class="flex bg-slate-100 p-1 rounded-full border">
            <button onclick="changeLang('zh')" class="lang-btn px-4 py-1 rounded-full text-sm font-medium transition-all bg-white shadow-sm" id="btn-zh">中文</button>
            <button onclick="changeLang('en')" class="lang-btn px-4 py-1 rounded-full text-sm font-medium transition-all" id="btn-en">EN</button>
            <button onclick="changeLang('sw')" class="lang-btn px-4 py-1 rounded-full text-sm font-medium transition-all" id="btn-sw">SW</button>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto p-6">
        
        <div class="flex flex-col md:flex-row gap-8 items-start mb-12">
            <div class="w-32 h-32 md:w-48 md:h-48 flex-shrink-0 mx-auto md:mx-0">
                <div class="ai-avatar rounded-full overflow-hidden bg-blue-100 h-full w-full">
                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=LiYaya&eyebrows=default&mouth=smile" alt="Li Yaya AI" class="w-full h-full object-cover">
                </div>
                <p class="text-center mt-3 font-bold text-blue-600">Li Yaya AI 老师</p>
            </div>
            
            <div class="speech-bubble p-6 shadow-sm flex-1">
                <h1 id="content-title" class="text-2xl font-bold text-blue-900 mb-4">载入中...</h1>
                <p id="content-speech" class="text-lg leading-relaxed text-slate-700 italic">
                    点击下方导航开始上课。
                </p>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-12">
            <button onclick="showSection(1)" class="nav-step py-3 px-2 rounded-xl border-2 font-medium transition-all hover:border-blue-500" id="step1">1. 开场白</button>
            <button onclick="showSection(2)" class="nav-step py-3 px-2 rounded-xl border-2 font-medium transition-all hover:border-blue-500" id="step2">2. 两滴油</button>
            <button onclick="showSection(3)" class="nav-step py-3 px-2 rounded-xl border-2 font-medium transition-all hover:border-blue-500" id="step3">3. 文化霸权</button>
            <button onclick="showSection(4)" class="nav-step py-3 px-2 rounded-xl border-2 font-medium transition-all hover:border-blue-500" id="step4">4. 整体框架</button>
            <button onclick="showSection(5)" class="nav-step py-3 px-2 rounded-xl border-2 font-medium transition-all hover:border-blue-500 bg-orange-50" id="step5">5. AI 实操</button>
        </div>

        <div id="main-content" class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100 min-h-[400px]">
            </div>

    </main>

    <script>
        // 三语数据中心
        const lessonData = {
            zh: {
                title: "两滴油的故事：文明的冲突与未来",
                steps: ["开场白", "两滴油", "文化帝国主义", "文明框架", "AI 练习"],
                sections: [
                    {
                        speech: "大家好！我是李丫丫。今天我们要在大树下，用丁香油和石油这两滴液体，拆解世界权力的秘密。",
                        body: `<div class='prose prose-blue max-w-none'><h2 class='text-xl font-bold mb-4'>欢迎来到 SAY Class</h2><p class='text-lg'>不要觉得这些事离我们很远，其实，每一滴油里都藏着桑给巴尔的过去，也藏着人类文明的未来。</p></div>`
                    },
                    {
                        speech: "左手丁香，右手石油。一滴代表土地的呼吸，一滴代表远古的能量。谁控制能量，谁就控制话语权。",
                        body: `<div class='grid md:grid-cols-2 gap-6'>
                            <div class='bg-amber-50 p-6 rounded-2xl'><h3>🏺 丁香油 (农业巅峰)</h3><p class='text-sm mt-2'>它是世界的黄金。为了它，苏丹迁都桑岛。它代表生物能与地理命运。</p></div>
                            <div class='bg-slate-900 text-white p-6 rounded-2xl'><h3>🛢️ 石油 (工业血液)</h3><p class='text-sm mt-2'>它是地底黑金。现在的战争本质上是为了争夺这瓶“黑水”。它代表化石能与现代博弈。</p></div>
                        </div>`
                    },
                    {
                        speech: "如果外乡人不仅拿走你的丁香，还说你的文化很土，只有学他才是文明人，这就是文化帝国主义。",
                        body: `<ul class='space-y-4'>
                            <li class='flex gap-4'><i class='fa-solid fa-crosshairs text-red-500 mt-1'></i> <div><b>不仅仅是大炮：</b> 帝国主义不只是占领土地。</div></li>
                            <li class='flex gap-4'><i class='fa-solid fa-brain text-purple-500 mt-1'></i> <div><b>大脑的占领：</b> 让你觉得“别人的总是好的，自己的是落后的”。</div></li>
                        </ul>`
                    },
                    {
                        speech: "把历史看成一棵大树。从为了生存空间，到为了灵魂秩序，再到为了石油与AI。",
                        body: `<div class='overflow-x-auto'><table class='w-full text-left border-collapse'>
                            <thead><tr class='bg-slate-50'>
                                <th class='p-3 border'>阶段</th><th class='p-3 border'>核心</th><th class='p-3 border'>SAY 视角</th>
                            </tr></thead>
                            <tbody>
                                <tr><td class='p-3 border'>远古</td><td class='p-3 border'>生存空间</td><td class='p-3 border'>耕作与水源</td></tr>
                                <tr><td class='p-3 border'>帝国</td><td class='p-3 border'>丁香香料</td><td class='p-3 border'>桑岛成为贸易中心</td></tr>
                                <tr><td class='p-3 border'>现代</td><td class='p-3 border'>石油数据</td><td class='p-3 border'>利用AI拿回发言权</td></tr>
                            </tbody>
                        </table></div>`
                    },
                    {
                        speech: "现在，轮到你们做架构师了！复制下方的 Prompt 尝试与 AI 对话。",
                        body: `<div class='bg-orange-50 border-2 border-dashed border-orange-200 p-6 rounded-2xl'>
                            <p class='font-bold mb-3'>📋 复制练习指令：</p>
                            <code id='promptCode' class='block bg-white p-4 rounded-lg text-sm mb-4'>“请用桑给巴尔石头城的一个老建筑作为例子，解释什么叫做‘文化融合’，并告诉我这里面包含哪些物理力学知识。”</code>
                            <button onclick='copyPrompt()' class='bg-orange-500 text-white px-6 py-2 rounded-full hover:bg-orange-600 transition-colors'>一键复制</button>
                        </div>`
                    }
                ]
            },
            en: {
                title: "A Story of Two Oils: Civilization and Future",
                steps: ["Intro", "Two Oils", "Imperialism", "Framework", "AI Practice"],
                sections: [
                    {
                        speech: "Hello! I am Li Yaya. Today, let's use clove oil and petroleum to deconstruct the secrets of world power.",
                        body: `<h2 class='text-xl font-bold mb-4'>Welcome to SAY Class</h2><p class='text-lg'>Zanzibar's past and the future of civilization are hidden in every drop of oil.</p>`
                    },
                    {
                        speech: "Cloves in the left hand, petroleum in the right. Whoever controls energy, controls the voice.",
                        body: `<div class='grid md:grid-cols-2 gap-6'>
                            <div class='bg-amber-50 p-6 rounded-2xl'><h3>🏺 Clove Oil</h3><p class='text-sm mt-2'>The peak of agricultural civilization. Sultan moved the capital for this gold.</p></div>
                            <div class='bg-slate-900 text-white p-6 rounded-2xl'><h3>🛢️ Petroleum</h3><p class='text-sm mt-2'>The blood of industry. Modern wars are fought for this 'black water'.</p></div>
                        </div>`
                    },
                    {
                        speech: "Culture Imperialism is when a stranger tells you your culture is primitive to justify taking your resources.",
                        body: `<p><b>It's not just cannons:</b> It's the occupation of the mind through books and screens.</p>`
                    },
                    {
                        speech: "History is like a tree, connecting ancient survival to modern AI tech race.",
                        body: `<p>We learn holistic education to see the hidden links between chemistry, history, and power.</p>`
                    },
                    {
                        speech: "Now, it's your turn to be the Prompt Architect!",
                        body: `<div class='bg-orange-50 border-2 border-dashed border-orange-200 p-6 rounded-2xl'>
                            <p class='font-bold mb-3'>📋 Copy Practice Prompt:</p>
                            <code class='block bg-white p-4 rounded-lg text-sm mb-4'>“Use an old building in Stone Town to explain 'Cultural Integration' and include the physics principles behind it.”</code>
                            <button onclick='copyPrompt()' class='bg-orange-500 text-white px-6 py-2 rounded-full'>Copy</button>
                        </div>`
                    }
                ]
            },
            sw: {
                title: "Hadithi ya Mafuta Mawili: Ustaarabu na Mustakabali",
                steps: ["Utangulizi", "Mafuta", "Ubeberu", "Mfumo", "AI Zoezi"],
                sections: [
                    {
                        speech: "Habari! Naitwa Li Yaya. Leo, tutatumia mafuta ya karafuu na petroli kuelewa siri za nguvu duniani.",
                        body: `<h2 class='text-xl font-bold mb-4'>Karibuni SAY Class</h2><p class='text-lg'>Kila tone la mafuta linaficha historia ya Zanzibar na mustakabali wetu.</p>`
                    },
                    {
                        speech: "Anayedhibiti nishati, ndiye anayedhibiti nguvu ya kusema.",
                        body: `<div class='grid md:grid-cols-2 gap-6'>
                            <div class='bg-amber-50 p-6 rounded-2xl'><h3>🏺 Mafuta ya Karafuu</h3><p class='text-sm mt-2'>Kilele cha kilimo. Sultani alihamia hapa kwa sababu ya dhahabu hii.</p></div>
                            <div class='bg-slate-900 text-white p-6 rounded-2xl'><h3>🛢️ Petroli</h3><p class='text-sm mt-2'>Damu ya viwanda. Vita vingi ni kwa sababu ya haya 'maji meusi'.</p></div>
                        </div>`
                    },
                    {
                        speech: "Ubeberu wa Kitamaduni ni mgeni anapokuambia utamaduni wako ni mbaya ili achukue utajiri wako.",
                        body: `<p><b>Sio mizinga pekee:</b> Ni uvamizi wa akili kupitia vitabu na simu.</p>`
                    },
                    {
                        speech: "Tunajifunza AI ili kurudisha sauti yetu katika ulimwengu wa kisasa.",
                        body: `<p>SAY Hub inakuunganisha na maarifa yote duniani.</p>`
                    },
                    {
                        speech: "Sasa, ni zamu yenu kuwa Prompt Architect!",
                        body: `<div class='bg-orange-50 border-2 border-dashed border-orange-200 p-6 rounded-2xl'>
                            <p class='font-bold mb-3'>📋 Nakili Prompt:</p>
                            <code class='block bg-white p-4 rounded-lg text-sm mb-4'>“Tumia jengo la kale la Stone Town kuelezea 'Cultural Integration' na kanuni za fizikia zilizotumika.”</code>
                            <button onclick='copyPrompt()' class='bg-orange-500 text-white px-6 py-2 rounded-full'>Copy</button>
                        </div>`
                    }
                ]
            }
        };

        let currentLang = 'zh';
        let currentSection = 1;

        function changeLang(lang) {
            currentLang = lang;
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('bg-white', 'shadow-sm'));
            document.getElementById(`btn-${lang}`).classList.add('bg-white', 'shadow-sm');
            updateUI();
        }

        function showSection(num) {
            currentSection = num;
            updateUI();
        }

        function updateUI() {
            const data = lessonData[currentLang];
            const section = data.sections[currentSection - 1];
            
            // 更新标题和气泡
            document.getElementById('content-title').innerText = data.title;
            document.getElementById('content-speech').innerText = section.speech;
            document.getElementById('main-content').innerHTML = section.body;
            
            // 更新导航按钮文字
            data.steps.forEach((text, i) => {
                document.getElementById(`step${i+1}`).innerText = `${i+1}. ${text}`;
            });

            // 更新激活状态
            document.querySelectorAll('.nav-step').forEach(btn => btn.classList.remove('step-active'));
            document.getElementById(`step${currentSection}`).classList.add('step-active');
            
            // 更新进度条
            document.getElementById('progressBar').style.width = `${(currentSection / 5) * 100}%`;
        }

        function copyPrompt() {
            const code = document.getElementById('promptCode').innerText;
            navigator.clipboard.writeText(code).then(() => {
                alert(currentLang === 'zh' ? "复制成功！去尝试对话吧。" : "Copied successfully!");
            });
        }

        // 初始化
        updateUI();
    </script>
</body>
</html>
